{
  "name": "blog-image-compression-tool",
  "version": "3.0.0",
  "private": true,
  "author": "blog-image-compression-tool contributors",
  "description": "Windows GUI and CLI batch image compression tool with static, animated GIF and JPEG gain map workflows.",
  "main": "src/electron/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "start": "electron .",
    "gui": "electron .",
    "convert": "node src/cli.js",
    "test": "node --test",
    "pack": "electron-builder --dir --win x64",
    "build:win": "electron-builder --win nsis portable --x64"
  },
  "dependencies": {
    "libavif-with-gainmap": "^0.1.15",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.eeg1412.blogimagecompressiontool",
    "productName": "博客图片压缩工具",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!node_modules/libavif-with-gainmap-win32-x64/vendor/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/libavif-with-gainmap-win32-x64/vendor/win32-x64/avifgainmapconvert.exe",
        "to": "native/avifgainmapconvert.exe"
      },
      {
        "from": "node_modules/libavif-with-gainmap-win32-x64/vendor/win32-x64/avifgainmapprobe.exe",
        "to": "native/avifgainmapprobe.exe"
      }
    ],
    "win": {
      "icon": "build/icon.svg",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "Blog-Image-Compression-Tool-${version}-${arch}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "博客图片压缩工具"
    },
    "portable": {
      "artifactName": "Blog-Image-Compression-Tool-${version}-${arch}-Portable.${ext}",
      "requestExecutionLevel": "user"
    }
  }
}
