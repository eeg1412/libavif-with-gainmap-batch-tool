# 最大边长。图片会等比例缩小，不会放大。
MAX_RESOLUTION=1920

# AVIF 主图质量，范围 0-100。
QUALITY=80

# Gain Map 质量，范围 0-100。
GAIN_MAP_QUALITY=85

# 是否移除 Exif/XMP 等元数据：true 移除，false 保留。
STRIP_METADATA=true

# libavif 编码速度：0 最慢、质量最好；10 最快。
SPEED=6

# 输入与输出目录。相对路径以项目根目录为基准。
INPUT_DIR=input
OUTPUT_DIR=output

# 传给 libavif 的线程数，可以是 all 或正整数。
THREADS=all
