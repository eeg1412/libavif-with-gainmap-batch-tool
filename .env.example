# 最大输出宽高。只会等比缩小，不会放大。
MAX_RESOLUTION=1920

# AVIF 主图质量，范围 0-100。
QUALITY=80

# Gain Map 质量，范围 0-100。
GAIN_MAP_QUALITY=70

# 是否去掉 Exif/XMP 等 metadata 信息。true 去掉，false 保留。
STRIP_METADATA=true

# libavif 编码速度。0 最慢，通常质量更好；10 最快。
SPEED=6

# 相对路径会从项目根目录解析，也支持绝对路径。
INPUT_DIR=input
OUTPUT_DIR=output

# 传给 libavif 的 jobs 参数。可以是 all，也可以是 4 这样的正整数。
THREADS=all
