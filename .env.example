# 通用非动画图片：输出格式可选 webp 或 avif。
STATIC_FORMAT=webp
STATIC_QUALITY=80
STATIC_MAX_RESOLUTION=1920

# 动画图片：目前仅多帧 GIF，输出格式目前仅支持 webp。
ANIMATED_FORMAT=webp
ANIMATED_QUALITY=80
ANIMATED_MAX_RESOLUTION=1920

# JPG Gain Map：输出格式目前仅支持 avif。
GAIN_MAP_FORMAT=avif
GAIN_MAP_BASE_QUALITY=80
GAIN_MAP_QUALITY=85
GAIN_MAP_MAX_RESOLUTION=1920

# 是否保留 Exif/XMP 等可能包含相机、位置和拍摄时间的元数据。
# 默认 false；图片仍会先根据 EXIF Orientation 摆正。
PRESERVE_METADATA=false

# libavif Gain Map 编码参数：速度 0 最慢、质量最好，10 最快。
SPEED=6
THREADS=all

# 输入与输出目录。相对路径以项目根目录为基准。
INPUT_DIR=input
OUTPUT_DIR=output

# 可选：自定义 libavif gainmap 原生工具目录。
# AVIF_GAINMAP_BIN_DIR=
